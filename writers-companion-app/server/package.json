{
  "name": "writers-companion-app",
  "version": "1.0.0",
  "description": "A writer's companion application that includes a text editor for book creation, an AI chatbox for editing suggestions, and story context management.",
  "main": "src/app.ts",
  "scripts": {
    "dev": "tsx src/app.ts",
    "start": "node dist/app.js",
    "build": "tsc",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cors": "^2.8.5",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "express-rate-limit": "^8.3.0",
    "mongoose": "^8.9.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.0.0",
    "@types/node": "^14.14.31",
    "@types/supertest": "^6.0.3",
    "jest": "^29.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^9.1.1",
    "tsx": "^4.19.3",
    "typescript": "^4.1.2"
  },
  "engines": {
    "node": ">=12.0.0"
  }
}
