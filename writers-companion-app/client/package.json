{
  "name": "writers-companion-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\""
  },
  "dependencies": {
    "axios": "^1.13.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-quill-new": "~3.7.0",
    "react-router-dom": "^6.0.0",
    "serialize-javascript": "^7.0.4",
    "styled-components": "^5.3.0",
    "typescript": "^4.1.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "jsdom": "^24.1.3",
    "@testing-library/react": "^13.4.0",
    "@testing-library/jest-dom": "^6.6.3"
  },
  "overrides": {
    "webpack-dev-server": "5.2.1",
    "quill": "2.0.2"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "jest": {
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\](?!axios).+\\.(js|jsx|mjs|cjs|ts|tsx)$",
      "^.+\\.module\\.(css|sass|scss)$"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
